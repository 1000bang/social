{
	"info": {
		"_postman_id": "7b1e4c2a-5d3f-4a1b-9c6e-2f8a1d4b7e3c",
		"name": "mySocial",
		"description": "소셜계정 관리 앱 API. 실행 전 mySocial Local environment를 선택하세요.\n\n순서:\n1. Auth > Get Login URL 실행 → 응답의 url을 브라우저로 열고 로그인/승인\n2. 리다이렉트된 mysocial://auth?token=... 에서 token 값을 복사해 jwt_token 환경변수에 붙여넣기\n3. Templates 폴더 요청들은 jwt_token을 자동으로 사용함\n4. Webhooks 폴더는 서명(X-Hub-Signature-256)을 pre-request script가 자동 계산함 — webhook_app_secret 환경변수만 실제 값으로 맞춰두면 됨",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Get Login URL",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/auth/instagram/login-url",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "instagram", "login-url"]
						},
						"description": "인증 불필요. 응답의 url을 브라우저에 붙여넣어 Meta 로그인/권한 동의를 진행하세요."
					},
					"response": []
				},
				{
					"name": "Instagram OAuth Callback (manual)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/auth/instagram/callback?code=PASTE_CODE_FROM_REDIRECT_HERE",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "instagram", "callback"],
							"query": [
								{
									"key": "code",
									"value": "PASTE_CODE_FROM_REDIRECT_HERE"
								}
							]
						},
						"description": "로그인 승인 후 Meta가 우리 서버로 리다이렉트할 때 넘겨주는 code 값을 query에 붙여넣고 실행하세요.\n\n주의: 응답은 302이며 Location 헤더가 mysocial://auth?token=... (성공) 또는 mysocial://auth?error=... (실패) 형태입니다. Postman이 커스텀 스킴을 못 따라가서 에러처럼 보일 수 있으니, Postman 설정에서 'Automatically follow redirects'를 끄고 응답 헤더의 Location 값을 직접 확인하세요. 여기서 얻은 token을 jwt_token 환경변수에 넣으면 됩니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "Templates",
			"auth": {
				"type": "bearer",
				"bearer": [
					{
						"key": "token",
						"value": "{{jwt_token}}",
						"type": "string"
					}
				]
			},
			"item": [
				{
					"name": "Create Template",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"이벤트 댓글 템플릿\",\n  \"postId\": {{post_id}},\n  \"dispatchTime\": \"09:00:00\",\n  \"keywords\": [\"이벤트\", \"참여\"],\n  \"dmKeyword\": \"이벤트참여\",\n  \"followerMessages\": [\n    { \"messageType\": \"TEXT\", \"textContent\": \"팔로워 감사 메시지입니다\" }\n  ],\n  \"nonFollowerMessages\": [\n    { \"messageType\": \"TEXT\", \"textContent\": \"댓글 남겨주셔서 감사합니다! 팔로우해주세요\" }\n  ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/api/templates",
							"host": ["{{base_url}}"],
							"path": ["api", "templates"]
						},
						"description": "postId는 실제 존재하는 post.id여야 합니다 (현재는 post 목록 조회 API가 없어 DB에 직접 있는 값을 써야 함)."
					},
					"response": []
				},
				{
					"name": "List Templates",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/templates",
							"host": ["{{base_url}}"],
							"path": ["api", "templates"]
						},
						"description": "jwt_token으로 식별된 계정의 템플릿만 조회됩니다."
					},
					"response": []
				},
				{
					"name": "Delete Template",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/templates/{{template_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "templates", "{{template_id}}"]
						},
						"description": "다른 계정 소유 템플릿이거나 존재하지 않으면 404가 반환됩니다."
					},
					"response": []
				}
			]
		},
		{
			"name": "Webhooks (Instagram)",
			"item": [
				{
					"name": "Verify Webhook (GET)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/webhooks/instagram?hub.mode=subscribe&hub.verify_token={{webhook_verify_token}}&hub.challenge=test_challenge_123",
							"host": ["{{base_url}}"],
							"path": ["webhooks", "instagram"],
							"query": [
								{ "key": "hub.mode", "value": "subscribe" },
								{ "key": "hub.verify_token", "value": "{{webhook_verify_token}}" },
								{ "key": "hub.challenge", "value": "test_challenge_123" }
							]
						},
						"description": "webhook_verify_token이 서버 설정값과 일치하면 200 + challenge 그대로 반환, 아니면 403."
					},
					"response": []
				},
				{
					"name": "Simulate Comment Event (matches keyword)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const payload = {",
									"  object: \"instagram\",",
									"  entry: [{",
									"    id: pm.environment.get(\"ig_business_account_id\"),",
									"    time: Math.floor(Date.now() / 1000),",
									"    changes: [{",
									"      field: \"comments\",",
									"      value: {",
									"        id: \"comment_\" + Date.now(),",
									"        text: \"이벤트 참여할게요!\",",
									"        from: { id: \"commenter_\" + Date.now(), username: \"postman_tester\" },",
									"        media: { id: pm.environment.get(\"media_id\"), media_product_type: \"FEED\" }",
									"      }",
									"    }]",
									"  }]",
									"};",
									"const body = JSON.stringify(payload);",
									"pm.environment.set(\"computed_body\", body);",
									"",
									"const secret = pm.environment.get(\"webhook_app_secret\");",
									"const hash = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
									"pm.request.headers.upsert({ key: \"X-Hub-Signature-256\", value: \"sha256=\" + hash });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{{computed_body}}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/webhooks/instagram",
							"host": ["{{base_url}}"],
							"path": ["webhooks", "instagram"]
						},
						"description": "템플릿에 등록된 키워드(이벤트/참여)와 매칭되는 댓글 웹훅을 시뮬레이션합니다. 먼저 ig_business_account_id/media_id 환경변수가 실제 account.platform_account_id / post.platform_post_id와 일치해야 매칭됩니다. 실행 후 dispatch_target 테이블에 PENDING row가 생기는지 DB로 확인하세요."
					},
					"response": []
				},
				{
					"name": "Simulate Comment Event (no keyword match)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const payload = {",
									"  object: \"instagram\",",
									"  entry: [{",
									"    id: pm.environment.get(\"ig_business_account_id\"),",
									"    time: Math.floor(Date.now() / 1000),",
									"    changes: [{",
									"      field: \"comments\",",
									"      value: {",
									"        id: \"comment_\" + Date.now(),",
									"        text: \"그냥 좋아요\",",
									"        from: { id: \"commenter_\" + Date.now(), username: \"postman_tester\" },",
									"        media: { id: pm.environment.get(\"media_id\"), media_product_type: \"FEED\" }",
									"      }",
									"    }]",
									"  }]",
									"};",
									"const body = JSON.stringify(payload);",
									"pm.environment.set(\"computed_body\", body);",
									"",
									"const secret = pm.environment.get(\"webhook_app_secret\");",
									"const hash = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
									"pm.request.headers.upsert({ key: \"X-Hub-Signature-256\", value: \"sha256=\" + hash });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{{computed_body}}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/webhooks/instagram",
							"host": ["{{base_url}}"],
							"path": ["webhooks", "instagram"]
						},
						"description": "키워드가 매칭되지 않는 댓글 — comment 테이블에는 저장되지만 dispatch_target에는 row가 생기지 않아야 정상입니다."
					},
					"response": []
				},
				{
					"name": "Simulate DM Keyword Event",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const payload = {",
									"  object: \"instagram\",",
									"  entry: [{",
									"    id: pm.environment.get(\"ig_business_account_id\"),",
									"    time: Math.floor(Date.now() / 1000),",
									"    messaging: [{",
									"      sender: { id: \"dm_sender_\" + Date.now() },",
									"      message: { mid: \"mid_\" + Date.now(), text: \"이벤트참여 하고싶어요\" }",
									"    }]",
									"  }]",
									"};",
									"const body = JSON.stringify(payload);",
									"pm.environment.set(\"computed_body\", body);",
									"",
									"const secret = pm.environment.get(\"webhook_app_secret\");",
									"const hash = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
									"pm.request.headers.upsert({ key: \"X-Hub-Signature-256\", value: \"sha256=\" + hash });"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{{computed_body}}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{base_url}}/webhooks/instagram",
							"host": ["{{base_url}}"],
							"path": ["webhooks", "instagram"]
						},
						"description": "템플릿의 dmKeyword(이벤트참여)와 매칭되는 DM 웹훅을 시뮬레이션합니다."
					},
					"response": []
				}
			]
		}
	]
}
